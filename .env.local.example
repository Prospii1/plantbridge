# Copy this file to .env.local and fill in the values.
# .env.local is gitignored — never commit it.

# ── Supabase ─────────────────────────────────────────────────────────────────
# Local dev: run `pnpm supabase start` and copy the keys it prints.
# Hosted: find these in your Supabase project settings → API.
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>

# SERVER ONLY — never import this in app/, components/, or lib/client/
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# ── App ───────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Stripe ───────────────────────────────────────────────────────────────────
# Create account at stripe.com — describe business as "wellness education and content platform"
# Test keys: https://dashboard.stripe.com/test/apikeys
# Webhook secret: `stripe listen --forward-to localhost:3000/api/stripe/webhook`
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
# Create a recurring price in Stripe dashboard for each tier, paste IDs here:
STRIPE_SELF_GUIDED_PRICE_ID=price_...
# Guided + Concierge prices — create in Stripe dashboard before enabling those tiers
# STRIPE_GUIDED_PRICE_ID=price_...
# STRIPE_CONCIERGE_PRICE_ID=price_...

# ── Resend (wire before email flows) ─────────────────────────────────────────
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=

# ── PostHog ───────────────────────────────────────────────────────────────────
# Get key from app.posthog.com → Project Settings → API keys
NEXT_PUBLIC_POSTHOG_KEY=phc_...
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ── Feature flags ────────────────────────────────────────────────────────────
# Set to 'true' to enable the dispensary product locator
NEXT_PUBLIC_FEATURE_DISPENSARY_LOCATOR=false
# Set to 'true' to enable Dutchie API product sync (Phase 4 — requires DUTCHIE_API_KEY)
DUTCHIE_SYNC_ENABLED=false

# ── Dutchie (Phase 4) ─────────────────────────────────────────────────────────
# API key from Dutchie partner portal
# DUTCHIE_API_KEY=

# ── Cron jobs ────────────────────────────────────────────────────────────────
# Secret shared between the effectiveness-cron edge function and /api/analytics/effectiveness
# Generate: openssl rand -hex 32
# CRON_SECRET=

# ── Sentry ────────────────────────────────────────────────────────────────────
# Get DSN from sentry.io → Project Settings → Client Keys
# SENTRY_AUTH_TOKEN is for source map uploads in CI only
NEXT_PUBLIC_SENTRY_DSN=https://...@sentry.io/...
# SENTRY_AUTH_TOKEN=sntrys_...
